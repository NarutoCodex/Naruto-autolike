{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/send-likes",
      "schedule": "30 23 * * *"
    }
  ],
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/admin", "dest": "public/admin.html" },
    { "src": "/cron-test", "dest": "/api/cron/send-likes" },
    { "src": "/(.*)", "dest": "public/$1" }
  ]
}
